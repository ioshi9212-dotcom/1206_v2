{
  "schema": "knowledge_index_v1_ru",
  "project": "akira-main-1206",
  "storage": {
    "static_character_knowledge": "characters/<character_id>/knowledge.yaml",
    "dynamic_character_memory": "state/character_knowledge/<character_id>.json"
  },
  "runtime_policy": [
    "Не грузить общий список знаний всех персонажей в gameplay-контекст.",
    "Для персонажа в сцене грузить его characters/<id>/knowledge.yaml как постоянную базу знаний.",
    "Для персонажа в сцене подтягивать state/character_knowledge/<id>.json как динамическую память сцены.",
    "Если персонаж не в сцене и не в фокусе, его dynamic knowledge state не подтягивать.",
    "Новые факты, увиденное, услышанное, важные реплики Акиры и выводы писать только в state/character_knowledge/<id>.json.",
    "Карточки main.yaml/character.yaml/past.yaml не использовать как mutable state."
  ],
  "characters": {
    "akira": {
      "display_name": "Акира",
      "static_file": "characters/akira/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/akira.json"
    },
    "jun": {
      "display_name": "Джун",
      "static_file": "characters/jun/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/jun.json"
    },
    "irey": {
      "display_name": "Ирэй",
      "static_file": "characters/irey/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/irey.json"
    },
    "emma": {
      "display_name": "Эмма",
      "static_file": "characters/emma/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/emma.json"
    },
    "raiden": {
      "display_name": "Райден",
      "static_file": "characters/raiden/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/raiden.json"
    },
    "ray": {
      "display_name": "Рэй",
      "static_file": "characters/ray/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/ray.json"
    },
    "yuna": {
      "display_name": "Юна",
      "static_file": "characters/yuna/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/yuna.json"
    },
    "miki": {
      "display_name": "Мики",
      "static_file": "characters/miki/knowledge.yaml",
      "dynamic_file": "state/character_knowledge/miki.json"
    }
  }
}
